{
  "name": "runcell",
  "version": "0.1.0",
  "description": "TypeScript runtime for running agents in sandboxes with structured results, file outputs, and persistent threads.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./pi": {
      "types": "./dist/pi.d.ts",
      "import": "./dist/pi.js",
      "default": "./dist/pi.js"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "del-cli dist && tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:live": "vitest --run --config vitest.live.config.ts",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@ai-sdk/sandbox-vercel": "1.0.0-beta.20"
  },
  "dependencies": {
    "@ai-sdk/harness": "1.0.0-beta.20",
    "@ai-sdk/provider-utils": "5.0.0-beta.49",
    "@ai-sdk/sandbox-just-bash": "1.0.0-beta.20",
    "@earendil-works/pi-coding-agent": "^0.79.0",
    "@standard-schema/spec": "^1.1.0",
    "zod": "^3.25.76 || ^4.1.8"
  },
  "devDependencies": {
    "@ai-sdk/sandbox-vercel": "1.0.0-beta.20",
    "@types/node": "^24.0.0",
    "del-cli": "^6.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "ai",
    "agent",
    "agent-runtime",
    "sandbox",
    "sandboxed-agents",
    "code-execution",
    "structured-output",
    "typescript",
    "llm",
    "ai-agents",
    "standard-schema",
    "zod"
  ],
  "peerDependenciesMeta": {
    "@ai-sdk/sandbox-vercel": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/D4NZ-jpg/runcell.git"
  },
  "homepage": "https://d4nz-jpg.github.io/runcell/",
  "bugs": {
    "url": "https://github.com/D4NZ-jpg/runcell/issues"
  }
}
