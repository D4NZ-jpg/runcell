{
  "name": "runcell",
  "version": "0.0.0",
  "description": "Build AI agents in TypeScript that return typed, validated data. Every run is sandboxed.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "del-cli dist && tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:live": "vitest --run --config vitest.live.config.ts"
  },
  "peerDependencies": {
    "@ai-sdk/sandbox-vercel": "1.0.0-beta.20"
  },
  "dependencies": {
    "@ai-sdk/harness": "1.0.0-beta.20",
    "@ai-sdk/provider-utils": "5.0.0-beta.49",
    "@ai-sdk/sandbox-just-bash": "1.0.0-beta.20",
    "@earendil-works/pi-coding-agent": "^0.79.0",
    "@standard-schema/spec": "^1.1.0"
  },
  "devDependencies": {
    "@ai-sdk/sandbox-vercel": "1.0.0-beta.20",
    "@types/node": "^24.0.0",
    "del-cli": "^6.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "zod": "^4.4.3"
  },
  "keywords": [
    "ai",
    "agent",
    "sandbox",
    "structured-output"
  ],
  "peerDependenciesMeta": {
    "@ai-sdk/sandbox-vercel": {
      "optional": true
    }
  }
}
