{
  "name": "runcell-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Monorepo for runcell: build AI agents in TypeScript that return typed, validated data.",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @local/harness-pi-raw && npm run build -w runcell",
    "typecheck": "npm run typecheck --workspaces --if-present && tsc -p examples/tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test --workspaces --if-present",
    "test:live": "npm run test:live -w runcell",
    "example:01": "npm run build && tsx examples/01-basic.ts",
    "example:02": "npm run build && tsx examples/02-output-validation.ts",
    "example:03": "npm run build && tsx examples/03-file-uploading.ts",
    "example:04": "npm run build && tsx examples/04-event-hooks.ts",
    "example:05": "npm run build && tsx examples/05-custom-tools.ts",
    "example:06": "npm run build && tsx examples/06-credentials.ts",
    "example:07": "tsx examples/07-shared-credential-store.ts",
    "example:08": "npm run build && tsx examples/08-file-output-validation.ts",
    "example:09": "npm run build && tsx examples/09-chat-agent.ts",
    "examples:run": "npm run build && tsx examples/01-basic.ts && tsx examples/02-output-validation.ts && tsx examples/03-file-uploading.ts && tsx examples/04-event-hooks.ts && tsx examples/05-custom-tools.ts && tsx examples/06-credentials.ts && tsx examples/07-shared-credential-store.ts && tsx examples/08-file-output-validation.ts && tsx examples/09-chat-agent.ts",
    "check": "npm run build && npm run format:check && npm run lint && npm run typecheck && npm run test",
    "prepare": "husky",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test:consumer": "node scripts/consumer-smoke.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.18.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.20.0",
    "vitepress": "^1.6.4",
    "zod": "3.25.76"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
